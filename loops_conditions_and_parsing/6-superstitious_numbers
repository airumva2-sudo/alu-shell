#!/usr/bin/env bash
# Lists numbers 1..20 with superstition messages for 4, 9, and 17 using a while loop.
i=1
while [ "$i" -le 20 ]
do
    echo "$i"
    case "$i" in
        4)
            echo "bad luck from China"
            ;;
        9)
            echo "bad luck from Japan"
            ;;
        17)
            echo "bad luck from Italy"
            ;;
    esac
    i=$((i + 1))
done
